# ═══════════════════════════════════════════════════════════════
# BagiTHR — Backend .env.example
# Standalone backend compose (MySQL + Mongo + Backend).
# ═══════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────
APP_ENV=production

# ── MySQL ─────────────────────────────────────────────────────
DB_PASSWORD=
DB_NAME=bagithr
DB_USER=root
DB_PORT=3307

# ── MongoDB ───────────────────────────────────────────────────
MONGO_USER=admin
MONGO_PASSWORD=
MONGO_DB_NAME=bagithr_indexer
MONGO_PORT=27017

# ── Backend Port ──────────────────────────────────────────────
BACKEND_PORT=8000

# ── Soroban / Stellar RPC ─────────────────────────────────────
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ── Contracts ─────────────────────────────────────────────────
SWAP_CONTRACT_ID=
NFT_GIFT_CONTRACT_ID=
MARKETPLACE_CONTRACT_ID=
MULTI_ROOM_CONTRACT_ID=
TOKEN_REGISTRY_CONTRACT_ID=
