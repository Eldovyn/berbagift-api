DB_NAME=bagithr
DB_USER=root
DB_PORT=3307

# ── MongoDB ───────────────────────────────────────────────────
MONGO_USER=admin
MONGO_PASSWORD=password
MONGO_DB_NAME=bagithr_indexer
MONGO_PORT=27017

# ── Backend Port ──────────────────────────────────────────────
